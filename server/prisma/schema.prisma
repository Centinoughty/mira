generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_DIRECT")
}

model User {
  id     String @id @default(uuid())
  name   String
  email  String @unique
  avatar String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
